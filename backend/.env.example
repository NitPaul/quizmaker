DJANGO_SECRET_KEY=replace-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AI providers (leave blank if users will supply their own key)
GROQ_API_KEY=
GEMINI_API_KEY=

# Celery broker — Upstash Redis (free) recommended for dev
# Example: rediss://default:PASSWORD@HOST.upstash.io:6379
CELERY_BROKER_URL=redis://localhost:6379/0
# Defaults to CELERY_BROKER_URL if blank
CELERY_RESULT_BACKEND=

# Supabase Postgres + pgvector (required for RAG / step 6 onward)
# Get this from Supabase: Project Settings -> Database -> Connection string -> URI
# DATABASE_URL=postgresql://USER:PASS@HOST:PORT/DBNAME
